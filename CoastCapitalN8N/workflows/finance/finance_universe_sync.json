            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Incremental Reference": {
      "main": [
        [
          {
            "node": "Get Final Stats",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Get Final Stats": {
