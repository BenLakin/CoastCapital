            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Check Price Coverage": {
      "main": [
        [
          {
            "node": "First Run?",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "First Run?": {
      "main": [
        [
          {
            "node": "Full Backfill Screener",
            "type": "main",
            "index": 0
          },
          {
            "node": "Full Backfill Reference",
            "type": "main",
            "index": 0
          }
        ],
        [
          {
            "node": "Incremental Screener",
            "type": "main",
            "index": 0
          },
          {
            "node": "Incremental Reference",
            "type": "main",
            "index": 0
          }
        ]
      ]
