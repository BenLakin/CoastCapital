        "text": "=[Sports] NFL game results ingested for {{ $now.format('yyyy-MM-dd') }}\nGames processed: {{ $json.games_ingested || 'check logs' }}",
        "otherOptions": {},
        "channel": "coast-recent-summaries"
      },
      "credentials": {
        "slackApi": {
          "id": "SOJFNoa56040Xc8Q",
          "name": "Slack account"
        }
      }
    },
    {
