    {
      "id": "node-aggregate",
      "name": "Aggregate Results",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2280,
        300
      ],
      "parameters": {
        "jsCode": "const services = [\n  { name: 'Finance (5000)', data: $('Health - Finance').first().json },\n  { name: 'HomeLab (5200)', data: $('Health - HomeLab').first().json },\n  { name: 'Assistant (5100)', data: $('Health - Assistant').first().json },\n  { name: 'Sports (5300)', data: $('Health - Sports').first().json },\n  { name: 'Maintenance API (8080)', data: $('Health - Maintenance API').first().json },\n];\n\nconst succeeded = [];\nconst failed = [];\n\nfor (const svc of services) {\n  const ok = svc.data && svc.data.status === 'healthy';\n  if (ok) {\n    succeeded.push(svc.name);\n  } else {\n    const reason = svc.data?.error || svc.data?.status || 'Unreachable';\n    failed.push(`${svc.name}: ${reason}`);\n  }\n}\n\nconst allSuccess = failed.length === 0;\n\nlet details = '';\nif (failed.length > 0) {\n  details = 'Failed: ' + failed.join(', ') + '. Succeeded: ' + succeeded.join(', ');\n} else {\n  details = 'All services: ' + succeeded.join(', ');\n}\n\nreturn [{\n  json: {\n    all_success: allSuccess,\n    succeeded,\n    failed,\n    details,\n    succeeded_count: succeeded.length,\n    failed_count: failed.length\n  }\n}];"
      }
    },
    {
      "id": "node-check-result",
      "name": "All Healthy?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        2500,
        300
      ],
      "parameters": {
        "conditions": {
          "conditions": [
            {
              "id": "cond-all-success",
              "leftValue": "={{ $json.all_success }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "node-slack-success",
      "name": "Slack - All Success",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 2.2,
      "position": [
