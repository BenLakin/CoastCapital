# =============================================================================
# CoastCapital Platform — Centralized Environment Configuration
# =============================================================================
# Copy to .env and fill in your values. This file is shared by ALL modules
# via docker-compose env_file: - ../.env
#
# NEVER commit .env to version control (see .gitignore).
# =============================================================================

# ── Global ──────────────────────────────────────────────────────────────────
TIMEZONE=America/New_York

# ── MySQL (central database) ────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change_me_strong_root_password
MYSQL_USER=dbadmin
MYSQL_PASSWORD=change_me_strong_user_password
MYSQL_HOST=coastcapital-mysql
MYSQL_PORT=3306

# ── Maintenance API ─────────────────────────────────────────────────────────
MAINTENANCE_API_KEY=change_me_api_key_for_n8n
MYSQL_MAINTENANCE_USER=maintenance
MYSQL_MAINTENANCE_PASSWORD=change_me_maintenance_password

# ── N8N Workflow Engine ─────────────────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=change_me_n8n_password
N8N_HOST=localhost
DOCKER_GID=999

# ── Slack ───────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret

# ── LLM Providers ──────────────────────────────────────────────────────────
# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-opus-4-6

# Google Gemini (Finance primary LLM)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Local Ollama (N8N Slack dispatcher, Finance secondary, HomeLab assistant)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b

# ── Git / Automation (for auto-MR on errors) ───────────────────────────────
GIT_USER_NAME=CoastCapital Bot
GIT_USER_EMAIL=bot@coastcapital.local
GIT_REMOTE_URL=https://github.com/your-org/CoastCapital.git

# ── Finance Module ──────────────────────────────────────────────────────────
FLASK_ENV=development
SECRET_KEY=your-super-secret-key-change-this
FINANCE_MYSQL_DATABASE=finance_silver

# API Keys
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
NEWS_API_KEY=your_news_api_key
POLYGON_API_KEY=your_polygon_key
FRED_API_KEY=

# Logging
LOG_LEVEL=INFO

# Forecasting defaults
DEFAULT_FORECAST_HORIZON=1
DEFAULT_LOOKBACK_DAYS=252
MIN_TRAINING_DAYS=252

# n8n webhook secret (for authenticating n8n calls)
N8N_WEBHOOK_SECRET=your-n8n-webhook-secret

# Default watchlist (comma-separated tickers)
DEFAULT_WATCHLIST=AAPL,MSFT,GOOGL,AMZN,NVDA,META,TSLA,JPM,BAC,WFC,SPY,QQQ

# LLM routing: "anthropic", "gemini", or "ollama"
LLM_PROVIDER_PRIMARY=gemini
LLM_PROVIDER_SECONDARY=ollama
LLM_MAX_ARTICLES_PER_STOCK=3

# ── HomeLab Module ──────────────────────────────────────────────────────────
# Flask (HomeLab-specific)
FLASK_SECRET_KEY=change-me-strong-secret-key
API_KEY=change-me-n8n-api-key
FLASK_DEBUG=false

# Local Mac monitoring (Docker host via host.docker.internal)
MONITOR_LOCAL=true
LOCAL_HOST=host.docker.internal
LOCAL_USER=your-mac-username
LOCAL_SSH_KEY=/run/secrets/ssh_key
LOCAL_SSH_PASSWORD=
LOCAL_MACHINE_NAME=Mac
LOCAL_MACHINE_DESC=Docker Host · macOS

# Remote Ubuntu Server (SSH)
SERVER_HOST=192.168.1.x
SERVER_USER=ubuntu
SERVER_SSH_KEY=/run/secrets/ssh_key
SERVER_SSH_PASSWORD=
SERVER_NAME=Ubuntu Server
SERVER_DESC=GPU Server · Ubuntu

# Extra machines (JSON array, for future expansion)
# EXTRA_MACHINES=[{"name":"GPU2","type":"ubuntu","host":"192.168.1.y","user":"ubuntu","ssh_key":"/run/secrets/ssh_key2"}]

# SSH key path on host (mounted into container)
SSH_KEY_PATH=~/.ssh/id_rsa

# UniFi Network / Protect
UNIFI_HOST=192.168.1.1
UNIFI_USERNAME=admin
UNIFI_PASSWORD=your-unifi-password
UNIFI_SITE=default
UNIFI_PORT=443

# Plex
PLEX_URL=http://192.168.1.x:32400
PLEX_TOKEN=your-plex-token

# Home Assistant
HA_URL=http://192.168.1.x:8123
HA_TOKEN=your-long-lived-access-token

# Ollama: Uses global OLLAMA_BASE_URL defined above

# Portainer
PORTAINER_URL=http://192.168.1.x:9000
PORTAINER_USERNAME=admin
PORTAINER_PASSWORD=your-portainer-password

# Homepage (optional)
HOMEPAGE_URL=http://192.168.1.x:3000

# ── Personal Assistant Module ───────────────────────────────────────────────
# iCloud Email & Calendar
ICLOUD_EMAIL=your@icloud.com
ICLOUD_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Owner & Family Contacts
OWNER_NAME=YourFirstName
OWNER_CITY=YourCity
KIM_LAKIN_EMAIL=kim@example.com
FAMILY_EMAILS=person1@example.com,person2@example.com
WEATHER_ZIP=94025

# ── Sports Module ───────────────────────────────────────────────────────────
MODEL_DIR=/app/model_artifacts

# LLM (Sports-specific — may override global)
LLM_PROVIDER=anthropic
# LLM_API_KEY — defaults to ANTHROPIC_API_KEY if not set
LLM_MODEL=claude-sonnet-4-20250514
LLM_BASE_URL=https://api.anthropic.com

# ── Platform Module (MCP dispatcher + Architecture Agent) ─────────────────
PLATFORM_API_KEY=change_me_platform_api_key
PLATFORM_MYSQL_DATABASE=maintenance_db
