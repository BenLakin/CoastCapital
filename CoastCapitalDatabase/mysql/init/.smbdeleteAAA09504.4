#!/bin/bash
# ─── Fix user passwords ──────────────────────────────────────────────────────
# SQL init files (.sql) cannot expand shell variables.  Docker runs .sh files
# through bash, so environment variables are available here.
#
# 01-schemas.sql creates reporting & maintenance users with literal '${...}'
# passwords.  This script ALTER USERs to set the real passwords from env vars.
# ──────────────────────────────────────────────────────────────────────────────

set -euo pipefail

REPORTING_PASS="${MYSQL_REPORTING_PASSWORD:-reporting_pass}"
MAINTENANCE_PASS="${MYSQL_MAINTENANCE_PASSWORD:-maintenance_pass}"

mysql -uroot -p"${MYSQL_ROOT_PASSWORD}" <<-EOSQL
    -- Fix reporting user password
    ALTER USER IF EXISTS 'reporting'@'%' IDENTIFIED BY '${REPORTING_PASS}';

    -- Fix maintenance user password
    ALTER USER IF EXISTS 'maintenance'@'%' IDENTIFIED BY '${MAINTENANCE_PASS}';

    FLUSH PRIVILEGES;
EOSQL

echo "[init] reporting and maintenance user passwords set from environment."
