[mysqld]
# ─── BASIC SETTINGS ────────────────────────────────────────────────────────────
user                        = mysql
pid-file                    = /var/run/mysqld/mysqld.pid
socket                      = /var/run/mysqld/mysqld.sock
port                        = 3306
bind-address                = 0.0.0.0

# ─── CHARACTER SET & COLLATION ─────────────────────────────────────────────────
character-set-server         = utf8mb4
collation-server             = utf8mb4_unicode_ci
character-set-filesystem     = utf8mb4
init-connect                 = 'SET NAMES utf8mb4'

# ─── InnoDB ENGINE (PRIMARY TUNING) ────────────────────────────────────────────
# Buffer pool: 70% of available RAM is recommended.
# Default 2G — override via environment if running on larger host.
innodb_buffer_pool_size      = 2G
innodb_buffer_pool_instances = 4          # 1 per 1G of buffer pool
# innodb_log_file_size is deprecated in 8.0.30+; use innodb_redo_log_capacity instead.
# Capacity = old file_size × file_count (512M × 2 = 1G).
innodb_redo_log_capacity     = 1073741824 # 1 GB
innodb_log_buffer_size       = 64M
innodb_flush_log_at_trx_commit = 1        # ACID-safe (2 = faster, less safe)
innodb_flush_method          = O_DIRECT   # avoid double buffering with OS
innodb_file_per_table        = ON         # separate ibd per table — easier maint.
innodb_io_capacity           = 2000       # IOPs — raise for SSD (4000+)
innodb_io_capacity_max       = 4000
innodb_read_io_threads       = 8
innodb_write_io_threads      = 8
innodb_purge_threads         = 4
innodb_autoinc_lock_mode     = 2          # interleaved — best for concurrency
innodb_stats_on_metadata     = OFF        # prevent stats recalc on every DESC
innodb_stats_auto_recalc     = ON
innodb_stats_persistent      = ON
innodb_stats_persistent_sample_pages = 25

# ─── CONNECTIONS & THREADS ─────────────────────────────────────────────────────
max_connections              = 500
max_connect_errors           = 10000
thread_cache_size            = 50
thread_stack                 = 256K

# ─── QUERY CACHE (disabled in MySQL 8 — kept explicit) ─────────────────────────
# query_cache_type is removed in MySQL 8+

# ─── TEMP TABLES & SORT BUFFERS ────────────────────────────────────────────────
tmp_table_size               = 256M
max_heap_table_size          = 256M
sort_buffer_size             = 4M         # per-session — keep modest
join_buffer_size             = 4M
read_buffer_size             = 2M
read_rnd_buffer_size         = 4M

# ─── TABLE CACHE ───────────────────────────────────────────────────────────────
table_open_cache             = 4000
table_definition_cache       = 2000
open_files_limit             = 65535

# ─── BINARY LOGGING (required for replication / PITR) ──────────────────────────
log_bin                      = /var/log/mysql/mysql-bin.log
binlog_format                = ROW
binlog_row_image             = MINIMAL
binlog_expire_logs_seconds   = 604800  # 7 days
max_binlog_size              = 256M
sync_binlog                  = 1

# ─── SLOW QUERY LOG ────────────────────────────────────────────────────────────
slow_query_log               = ON
slow_query_log_file          = /var/log/mysql/slow.log
long_query_time              = 1          # seconds — queries slower than this
log_queries_not_using_indexes = ON
min_examined_row_limit       = 100

# ─── GENERAL & ERROR LOGGING ───────────────────────────────────────────────────
log_error                    = /var/log/mysql/error.log
log_error_verbosity          = 3
general_log                  = OFF        # enable temporarily for debugging

# ─── REPLICATION (future-ready) ────────────────────────────────────────────────
server-id                    = 1
gtid_mode                    = ON
enforce_gtid_consistency     = ON

# ─── PERFORMANCE SCHEMA ────────────────────────────────────────────────────────
performance_schema           = ON
performance_schema_events_waits_history_size  = 40
performance_schema_events_statements_history_size = 40
performance_schema_events_stages_history_size = 40

# ─── SECURITY ──────────────────────────────────────────────────────────────────
local_infile                 = OFF
# skip_symbolic_links removed in MySQL 8.2+ — symbolic-links=0 is now the default
sql_mode                     = STRICT_TRANS_TABLES,NO_ZERO_IN_DATE,NO_ZERO_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION

# ─── TIMEOUTS ──────────────────────────────────────────────────────────────────
wait_timeout                 = 600
interactive_timeout          = 600
net_read_timeout             = 30
net_write_timeout            = 60
lock_wait_timeout            = 50

# ─── OPTIMIZER ─────────────────────────────────────────────────────────────────
optimizer_switch             = "index_merge=on,index_merge_union=on,index_merge_sort_union=on,index_merge_intersection=on,engine_condition_pushdown=on,index_condition_pushdown=on,mrr=on,mrr_cost_based=on,block_nested_loop=on,batched_key_access=off,materialization=on,semijoin=on,loosescan=on,firstmatch=on,duplicateweedout=on,subquery_materialization_cost_based=on,use_index_extensions=on,condition_fanout_filter=on,derived_merge=on"

[mysql]
default-character-set        = utf8mb4

[client]
default-character-set        = utf8mb4
