# ─── Copy this file to .env and fill in the values ────────────────────────────
# CoastCapitalDatabase — local environment template
# (If you run from the monorepo root, the parent ../.env takes precedence.)

# ─── MySQL ─────────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change_me_strong_root_password
MYSQL_DATABASE=coastcapital
MYSQL_USER=dbadmin
MYSQL_PASSWORD=change_me_strong_user_password

# ─── Additional DB users created by init SQL ───────────────────────────────────
MYSQL_MAINTENANCE_USER=maintenance
MYSQL_MAINTENANCE_PASSWORD=change_me_maintenance_password
COASTWEB_APP_PASSWORD=change_me_coastweb_app_password

# ─── Maintenance API (port 8080) ───────────────────────────────────────────────
MAINTENANCE_API_KEY=change_me_maintenance_api_key

# ─── CoastWeb Logging API (port 8081) ─────────────────────────────────────────
COASTWEB_API_KEY=change_me_coastweb_api_key
